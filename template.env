DATASTORE_READONLY_PASSWORD=readonlypw
CKAN_MAX_UPLOAD_SIZE_MB=1000
CKAN_ADMIN_PASSWORD=administrator
BEAKER_SESSION_SECRET=changeme-use-a-long-random-string

DOI_PREFIX=
